# Copy to backend/.env on the server. Do not commit real secrets.

# --- Data source: local disk vs R2 ---
# local = only frontend/data + compressed_computed_data on this machine (R2 credentials ignored).
# Omit or use r2 = read from R2 when R2_* credentials are set.
# DATA_SOURCE=local
# USE_LOCAL_DATA=1

# --- Cloudflare R2 (S3-compatible) ---
# Objects mirror frontend/data/: e.g. data/schedule/2025.json, data/replays/2025_r01_R/meta.json
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_KEY_PREFIX=

# Precomputed telemetry (same layout as local compressed_computed_data/*.pkl.xz):
#   compressed_computed_data/<filename>.pkl.xz
# load_computed_pickle tries local disk first, then R2. On a server with no local tree, use:
# R2_COMPUTED_FIRST=1
# R2_DISABLE_COMPUTED=1  # optional: never read pickles from R2

# --- R2-only API (no FastF1 / no local FastF1 cache dir) ---
# Set to 1 to load schedule, default-year, and session replays only from R2.
R2_ONLY_SERVER=0

# Or keep FastF1 for schedule but load sessions from R2 bundles only:
# SESSION_LOAD_FROM_R2=1

# Optional: put FastF1 cache on tmpfs when you still use FastF1 (e.g. hybrid dev)
# FASTF1_CACHE_DIR=/tmp/fastf1-cache

# No FastF1 files on disk — always hit live API; use R2 for precomputed pickles (see R2_COMPUTED_FIRST)
# FASTF1_DISK_CACHE=0

# When a precomputed telemetry pickle exists (R2 or local), skip FastF1 session.load() (default on).
# Set to 0 if you need full FastF1 metadata (teams, rotation, event names) after loading a pickle.
# SKIP_FASTF1_WHEN_PRECOMPUTED=0

# CORS for your Vercel / static frontend origin
# CORS_ORIGINS=https://your-app.vercel.app

# SERVE_FRONTEND=0

# Optional: static site root (default: repo ``frontend/``, else ``web/public/`` if only that exists)
# STATIC_SITE_DIR=/path/to/site

# After deploy: curl -s http://127.0.0.1:8000/api/health/r2
# Prefer example_race_pickle_head_ok + summary; optional JSON is example_json_meta_*.
